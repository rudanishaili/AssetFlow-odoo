datasource db {
  provider = "mysql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AssignmentStatus {
  ACTIVE
  RETURNED
  OVERDUE
}

enum RequestType {
  ALLOCATION
  TRANSFER
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum AuditCycleStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

enum AuditItemStatus {
  PENDING
  VERIFIED
  MISSING
  DAMAGED
}

enum DiscrepancyStatus {
  OPEN
  RESOLVED
}

enum NotificationType {
  SYSTEM
  ALLOCATION
  MAINTENANCE
  BOOKING
  TRANSFER
  AUDIT
}

model User {
  id                String             @id @default(uuid())
  name              String
  email             String             @unique
  password          String
  role              Role               @default(EMPLOYEE)
  status            UserStatus         @default(ACTIVE)
  
  // Relations
  departmentId      String?
  department        Department?        @relation("DepartmentEmployees", fields: [departmentId], references: [id])
  
  // A user can be the head of a department
  headedDepartment  Department?        @relation("DepartmentHead")

  // Operations
  assignments       AssetAssignment[]  @relation("EmployeeAssignments")
  requests          AssetRequest[]     @relation("RequesterRequests")
  targetRequests    AssetRequest[]     @relation("TargetEmployeeRequests")
  actionedRequests  AssetRequest[]     @relation("ActionedRequests")
  
  raisedMaintenance MaintenanceRequest[] @relation("RaisedMaintenanceRequests")
  actionedMaintenance MaintenanceRequest[] @relation("ActionedMaintenanceRequests")
  
  bookings          ResourceBooking[]
  auditorItems      AuditItem[]
  resolvedDiscrepancies AuditDiscrepancy[]
  
  notifications     Notification[]
  auditLogs         AuditLog[]

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([email])
  @@index([departmentId])
}

model Department {
  id               String            @id @default(uuid())
  name             String            @unique
  status           UserStatus        @default(ACTIVE)
  
  // Hierarchy
  parentId         String?
  parent           Department?       @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  subDepartments   Department[]      @relation("DepartmentHierarchy")

  // Department Head
  headId           String?           @unique
  head             User?             @relation("DepartmentHead", fields: [headId], references: [id])

  // Employees in the department
  employees        User[]            @relation("DepartmentEmployees")

  // Target of assignments and requests
  assignments      AssetAssignment[]
  requests         AssetRequest[]

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([parentId])
}

model Category {
  id                String   @id @default(uuid())
  name              String   @unique
  description       String?
  
  // dynamic fields specification stored as JSON (e.g. [{"name": "warrantyMonths", "type": "number"}])
  customFieldSpecs  Json?

  assets            Asset[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Vendor {
  id          String   @id @default(uuid())
  name        String
  email       String?
  phone       String?
  address     String?
  
  assets      Asset[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Asset {
  id                String              @id @default(uuid())
  name              String
  assetTag          String              @unique // e.g. AF-0001
  serialNumber      String              @unique
  acquisitionDate   DateTime
  acquisitionCost   Decimal             @db.Decimal(12, 2)
  condition         AssetCondition      @default(NEW)
  location          String
  isSharedBookable  Boolean             @default(false)
  status            AssetStatus         @default(AVAILABLE)
  
  // Dynamic field values matching category customFieldSpecs
  customFieldValues Json?

  // Relations
  categoryId        String
  category          Category            @relation(fields: [categoryId], references: [id])
  
  vendorId          String?
  vendor            Vendor?             @relation(fields: [vendorId], references: [id])

  warranty          Warranty?
  purchaseDetails   PurchaseDetails?
  
  images            AssetImage[]
  assignments       AssetAssignment[]
  requests          AssetRequest[]
  bookings          ResourceBooking[]
  maintenance       MaintenanceRequest[]
  auditItems        AuditItem[]

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([categoryId])
  @@index([vendorId])
  @@index([status])
  @@index([location])
}

model AssetImage {
  id        String   @id @default(uuid())
  url       String
  
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
}

model Warranty {
  id          String   @id @default(uuid())
  provider    String
  startDate   DateTime
  endDate     DateTime
  contactInfo String?
  terms       String?  @db.Text

  assetId     String   @unique
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PurchaseDetails {
  id                  String   @id @default(uuid())
  invoiceNumber       String
  purchaseOrderNumber String?
  purchaseDate        DateTime
  cost                Decimal  @db.Decimal(12, 2)

  assetId             String   @unique
  asset               Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model AssetAssignment {
  id                    String           @id @default(uuid())
  assignedDate          DateTime         @default(now())
  expectedReturnDate    DateTime?
  returnedDate          DateTime?
  conditionCheckInNotes String?          @db.Text
  status                AssignmentStatus @default(ACTIVE)

  // Relations
  assetId               String
  asset                 Asset            @relation(fields: [assetId], references: [id], onDelete: Cascade)

  // Can be assigned to employee or department
  employeeId            String?
  employee              User?            @relation("EmployeeAssignments", fields: [employeeId], references: [id])

  departmentId          String?
  department            Department?      @relation(fields: [departmentId], references: [id])

  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([assetId])
  @@index([employeeId])
  @@index([departmentId])
  @@index([status])
}

model AssetRequest {
  id                  String        @id @default(uuid())
  requestType         RequestType   @default(ALLOCATION)
  status              RequestStatus @default(PENDING)
  notes               String?       @db.Text
  
  // Relations
  assetId             String
  asset               Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)

  requesterId         String
  requester           User          @relation("RequesterRequests", fields: [requesterId], references: [id])

  targetEmployeeId    String?
  targetEmployee      User?         @relation("TargetEmployeeRequests", fields: [targetEmployeeId], references: [id])

  targetDepartmentId  String?
  targetDepartment    Department?   @relation(fields: [targetDepartmentId], references: [id])

  actionedById        String?
  actionedBy          User?         @relation("ActionedRequests", fields: [actionedById], references: [id])

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([assetId])
  @@index([requesterId])
  @@index([status])
}

model ResourceBooking {
  id        String        @id @default(uuid())
  startTime DateTime
  endTime   DateTime
  status    BookingStatus @default(UPCOMING)

  // Relations
  assetId   String
  asset     Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)

  bookerId  String
  booker    User          @relation(fields: [bookerId], references: [id])

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([assetId])
  @@index([bookerId])
  @@index([status])
  @@index([startTime, endTime])
}

model MaintenanceRequest {
  id                  String              @id @default(uuid())
  issueDescription    String              @db.Text
  priority            MaintenancePriority @default(MEDIUM)
  status              MaintenanceStatus   @default(PENDING)
  technicianName      String?
  cost                Decimal?            @db.Decimal(12, 2)
  nextMaintenanceDate DateTime?
  scheduledDate       DateTime?
  completedDate       DateTime?
  notes               String?             @db.Text

  // Relations
  assetId             String
  asset               Asset               @relation(fields: [assetId], references: [id], onDelete: Cascade)

  raisedById          String
  raisedBy            User                @relation("RaisedMaintenanceRequests", fields: [raisedById], references: [id])

  approvedById        String?
  approvedBy          User?               @relation("ActionedMaintenanceRequests", fields: [approvedById], references: [id])

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([assetId])
  @@index([status])
  @@index([raisedById])
}

model AuditCycle {
  id                 String           @id @default(uuid())
  name               String
  scopeLocation      String?
  startDate          DateTime
  endDate            DateTime
  status             AuditCycleStatus @default(PLANNED)

  // Relations
  scopeDepartmentId  String?

  auditItems         AuditItem[]

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([status])
}

model AuditItem {
  id                String          @id @default(uuid())
  status            AuditItemStatus @default(PENDING)
  verificationNotes String?         @db.Text

  // Relations
  auditCycleId      String
  auditCycle        AuditCycle      @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)

  assetId           String
  asset             Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)

  auditorId         String
  auditor           User            @relation(fields: [auditorId], references: [id])

  discrepancies     AuditDiscrepancy[]

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([auditCycleId])
  @@index([assetId])
  @@index([auditorId])
  @@index([status])
}

model AuditDiscrepancy {
  id              String            @id @default(uuid())
  description     String            @db.Text
  status          DiscrepancyStatus @default(OPEN)
  resolutionNotes String?           @db.Text

  // Relations
  auditItemId     String
  auditItem       AuditItem         @relation(fields: [auditItemId], references: [id], onDelete: Cascade)

  resolvedById    String?
  resolvedBy      User?             @relation(fields: [resolvedById], references: [id])

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([auditItemId])
  @@index([status])
}

model Notification {
  id        String           @id @default(uuid())
  title     String
  message   String           @db.Text
  isRead    Boolean          @default(false)
  type      NotificationType @default(SYSTEM)

  // Relations
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId])
  @@index([isRead])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  details   Json?
  ipAddress String?

  // Relations
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
