# --- ROOT ENVIRONMENT CONFIGURATION ---
# Copy this file to client/.env and server/.env and customize

# Client Configuration
VITE_API_URL=http://localhost:5000/api
VITE_APP_NAME=AssetFlow
VITE_THEME=dark

# Server Configuration
PORT=5000
NODE_ENV=development
JWT_SECRET=your_jwt_secret_key_change_me_in_production
JWT_EXPIRES_IN=7d

# Database Settings
DATABASE_URL="mysql://root:password@localhost:3306/assetflow"

# Cloudinary Integration (for FormUpload / File uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
